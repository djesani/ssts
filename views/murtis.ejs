<!DOCTYPE html>
<html>

<head>
  <% include partials/header %>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Karla:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --gold: #c9963a;
      --gold-light: #e8bc68;
      --deep: #1a0f00;
      --cream: #fdf6ec;
      --muted: #8a7560;
      --text: #3a2810;
    }

    .styled-page {
      background: var(--cream);
      color: var(--text);
      font-family: 'Karla', sans-serif;
      padding-bottom: 40px;
    }

    .page-header {
      text-align: center;
      padding: 40px 24px 36px;
      position: relative;
    }

    .page-header::after {
      content: '';
      display: block;
      width: 60px;
      height: 2px;
      background: var(--gold);
      margin: 24px auto 0;
    }

    .page-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      font-weight: 300;
      letter-spacing: 0.12em;
      color: var(--deep);
      text-transform: uppercase;
    }

    .page-header .subtitle {
      font-size: 0.9rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 8px;
      font-weight: 500;
    }

    .page-intro {
      font-size: 1.12rem;
      font-style: italic;
      color: var(--muted);
      text-align: center;
      max-width: 700px;
      margin: 0 auto;
      padding: 20px 24px 10px;
      line-height: 1.85;
    }

    .murtis-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 24px;
      padding: 32px 24px;
      max-width: 1100px;
      margin: 0 auto;
    }

    .murti-card {
      background: #fff;
      border-radius: 4px;
      overflow: hidden;
      cursor: pointer;
      transition: transform 0.4s ease, box-shadow 0.4s ease;
      box-shadow: 0 2px 12px rgba(26, 15, 0, 0.08);
      border: 1px solid rgba(201, 150, 58, 0.15);
    }

    .murti-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(201, 150, 58, 0.2);
    }

    .murti-card-img {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      display: block;
      transition: transform 0.5s ease;
    }

    .murti-card:hover .murti-card-img {
      transform: scale(1.04);
    }

    .murti-card-info {
      padding: 14px 16px;
      text-align: center;
      border-top: 1px solid rgba(201, 150, 58, 0.15);
    }

    .murti-card-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--deep);
      letter-spacing: 0.03em;
    }

    /* Lightbox */
    .murti-lightbox {
      position: fixed;
      inset: 0;
      background: rgba(10, 8, 5, 0.95);
      z-index: 99999;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .murti-lightbox.open {
      display: flex;
    }

    .murti-lightbox-inner {
      max-width: 600px;
      width: 100%;
      text-align: center;
    }

    .murti-lightbox-img-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 70vh;
      background: rgba(26, 15, 0, 0.5);
      border-radius: 4px;
      overflow: hidden;
    }

    .murti-lightbox-img-wrap img {
      max-width: 100%;
      height: 70vh;
      object-fit: contain;
      display: block;
    }

    .murti-lightbox-info {
      padding: 20px 0 0;
    }

    .murti-lightbox-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 400;
      color: #f5ead8;
      letter-spacing: 0.04em;
    }

    .murti-lightbox-counter {
      font-family: 'Karla', sans-serif;
      font-size: 0.85rem;
      color: var(--gold);
      margin-top: 6px;
      letter-spacing: 0.1em;
    }

    .murti-lb-close {
      position: absolute;
      top: 20px;
      right: 20px;
      background: none;
      border: none;
      color: #d4c4a0;
      font-size: 1.4rem;
      cursor: pointer;
      padding: 4px 8px;
      transition: color 0.3s;
      z-index: 1;
    }

    .murti-lb-close:hover { color: var(--gold); }

    .murti-lb-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: 1px solid rgba(61, 51, 34, 0.5);
      color: #d4c4a0;
      font-size: 1.6rem;
      padding: 8px 14px;
      cursor: pointer;
      transition: all 0.3s;
      border-radius: 2px;
    }

    .murti-lb-nav:hover {
      border-color: var(--gold);
      color: var(--gold);
    }

    .murti-lb-prev { left: 20px; }
    .murti-lb-next { right: 20px; }

    @media (max-width: 640px) {
      .murti-lb-nav {
        font-size: 1.2rem;
        padding: 6px 10px;
      }
      .murti-lb-prev { left: 8px; }
      .murti-lb-next { right: 8px; }
    }
  </style>
</head>

<body>
  <% include partials/menu %>
    <div class="container bg-light">
      <div class="styled-page">
        <div class="page-header">
          <p class="subtitle">Sacred Deities</p>
          <h1>Murtis</h1>
        </div>

        <p class="page-intro">The divine murtis installed and consecrated at Shree Swaminarayan Mandir Bhuj &ndash; Sydney.</p>

        <div class="murtis-grid" id="murtisGrid"></div>
      </div>
    </div>

  <!-- Lightbox -->
  <div class="murti-lightbox" id="murtiLightbox">
    <button class="murti-lb-close" onclick="closeMurtiLb()">&times;</button>
    <button class="murti-lb-nav murti-lb-prev" onclick="murtiLbNav(-1)">&lsaquo;</button>
    <button class="murti-lb-nav murti-lb-next" onclick="murtiLbNav(1)">&rsaquo;</button>
    <div class="murti-lightbox-inner">
      <div class="murti-lightbox-img-wrap">
        <img id="murtiLbImg" src="" alt="">
      </div>
      <div class="murti-lightbox-info">
        <div class="murti-lightbox-title" id="murtiLbTitle"></div>
        <div class="murti-lightbox-counter" id="murtiLbCounter"></div>
      </div>
    </div>
  </div>

  <script>
    var murtisData = [
      { name: 'Shree Ghanshyam Maharaj', image: 'images/murtis/GhanshyamMaharaj.png' },
      { name: 'Shree Nar Narayan Dev', image: 'images/murtis/NarnarayanDev.png' },
      { name: 'Shree Sahajanand Swami', image: 'images/murtis/SwaminarayanBhagwan.png' },
      { name: 'Shree Radha Krishna Dev', image: 'images/murtis/Radhakrishna.png' },
      { name: 'Shree Shiv Parvati', image: 'images/murtis/ShivParvati.png' },
      { name: 'Shree Ganeshji', image: 'images/murtis/GaneshBhagwan.png' },
      { name: 'Shivling', image: 'images/murtis/Shivling.png' },
      { name: 'Shree Ram, Sita and Lakshman', image: 'images/murtis/LakshmanRamSita.png' },
      { name: 'Shree Hanumanji', image: 'images/murtis/Hanumanji.png' },
      { name: 'Shree Surya Narayan Dev', image: 'images/murtis/SuryaNarayanDev.png' },
      { name: 'Shree Harikrishna Maharaj', image: 'images/murtis/Harikrishna Maharaj.png' },
      { name: 'Shree Saligram', image: 'images/murtis/saligram.png' },
      { name: 'Shree Saligram (Top View)', image: 'images/murtis/saligam-top-view.png' },
      { name: 'Shree Kurma', image: 'images/murtis/kurma.png' },
      { name: 'Nandi', image: 'images/murtis/nandi.png' }
    ];

    var currentMurti = 0;

    // Build grid
    var gridHtml = '';
    murtisData.forEach(function(murti, idx) {
      gridHtml += '<div class="murti-card" onclick="openMurtiLb(' + idx + ')">' +
        '<img src="' + murti.image + '" alt="' + murti.name + '" class="murti-card-img">' +
        '<div class="murti-card-info"><div class="murti-card-name">' + murti.name + '</div></div>' +
        '</div>';
    });
    document.getElementById('murtisGrid').innerHTML = gridHtml;

    function openMurtiLb(i) {
      currentMurti = i;
      renderMurtiLb();
      document.getElementById('murtiLightbox').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeMurtiLb() {
      document.getElementById('murtiLightbox').classList.remove('open');
      document.body.style.overflow = '';
    }

    function murtiLbNav(dir) {
      currentMurti = (currentMurti + dir + murtisData.length) % murtisData.length;
      renderMurtiLb();
    }

    function renderMurtiLb() {
      var m = murtisData[currentMurti];
      document.getElementById('murtiLbImg').src = m.image;
      document.getElementById('murtiLbImg').alt = m.name;
      document.getElementById('murtiLbTitle').textContent = m.name;
      document.getElementById('murtiLbCounter').textContent = (currentMurti + 1) + ' / ' + murtisData.length;
    }

    document.getElementById('murtiLightbox').addEventListener('click', function(e) {
      if (e.target === this) closeMurtiLb();
    });

    document.addEventListener('keydown', function(e) {
      if (document.getElementById('murtiLightbox').classList.contains('open')) {
        if (e.key === 'ArrowRight') murtiLbNav(1);
        if (e.key === 'ArrowLeft') murtiLbNav(-1);
        if (e.key === 'Escape') closeMurtiLb();
      }
    });
  </script>

  <% include partials/footer %>
</body>

</html>
