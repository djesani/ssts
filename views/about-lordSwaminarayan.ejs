<!DOCTYPE html>
<html>

<head>
  <% include partials/header %>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Karla:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --gold: #c9963a;
      --gold-light: #e8bc68;
      --deep: #1a0f00;
      --cream: #fdf6ec;
      --muted: #8a7560;
      --text: #3a2810;
    }

    .styled-page {
      background: var(--cream);
      color: var(--text);
      font-family: 'Karla', sans-serif;
      padding-bottom: 40px;
    }

    .page-header {
      text-align: center;
      padding: 40px 24px 36px;
      position: relative;
    }

    .page-header::after {
      content: '';
      display: block;
      width: 60px;
      height: 2px;
      background: var(--gold);
      margin: 24px auto 0;
    }

    .page-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      font-weight: 300;
      letter-spacing: 0.12em;
      color: var(--deep);
      text-transform: uppercase;
    }

    .page-header .subtitle {
      font-size: 0.9rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 8px;
      font-weight: 500;
    }

    .page-intro {
      font-size: 1.12rem;
      font-style: italic;
      color: var(--muted);
      text-align: center;
      max-width: 700px;
      margin: 0 auto;
      padding: 20px 24px 10px;
      line-height: 1.85;
    }

    .page-content {
      max-width: 800px;
      margin: 0 auto;
      padding: 20px 24px;
    }

      .about-section {
        padding: 32px 0;
        border-bottom: 1px solid rgba(201, 150, 58, 0.15);
        scroll-margin-top: 80px;
      }


    .page-section:last-child { border-bottom: none; }

    .page-section p {
      font-size: 1.1rem;
      line-height: 1.85;
      color: var(--text);
      margin-bottom: 14px;
    }

    .page-section img {
      max-width: 100%;
      height: auto;
      border-radius: 4px;
      margin-bottom: 20px;
    }

    .page-section img.float-right {
      float: right;
      max-width: 225px;
      margin: 0 0 16px 24px;
    }

    .page-section::after {
      content: '';
      display: table;
      clear: both;
    }

    .lineage-list {
      list-style: none;
      padding: 0;
      margin: 0;
      counter-reset: lineage;
    }

    .lineage-list li {
      font-size: 1.1rem;
      line-height: 1.85;
      color: var(--text);
      padding: 10px 0 10px 40px;
      position: relative;
      border-bottom: 1px solid rgba(201, 150, 58, 0.15);
      counter-increment: lineage;
    }

    .lineage-list li::before {
      content: counter(lineage);
      position: absolute;
      left: 0;
      color: var(--gold);
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 600;
      width: 28px;
      text-align: center;
    }

    .lineage-list li:last-child {
      border-bottom: none;
      font-weight: 500;
      color: var(--deep);
    }

    @media (max-width: 576px) {
      .page-section img.float-right {
        float: none;
        max-width: 100%;
        margin: 0 0 16px 0;
      }
    }

  </style>
</head>

