<!DOCTYPE html>
<html>

<head>
  <% include partials/header %>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Karla:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --gold: #c9963a;
      --gold-light: #e8bc68;
      --deep: #1a0f00;
      --cream: #fdf6ec;
      --muted: #8a7560;
      --text: #3a2810;
    }

    .styled-page {
      background: var(--cream);
      color: var(--text);
      font-family: 'Karla', sans-serif;
      padding-bottom: 40px;
    }

    .page-header {
      text-align: center;
      padding: 40px 24px 36px;
      position: relative;
    }

    .page-header::after {
      content: '';
      display: block;
      width: 60px;
      height: 2px;
      background: var(--gold);
      margin: 24px auto 0;
    }

    .page-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      font-weight: 300;
      letter-spacing: 0.12em;
      color: var(--deep);
      text-transform: uppercase;
    }

    .page-header .subtitle {
      font-size: 0.9rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 8px;
      font-weight: 500;
    }

    .page-content {
      max-width: 800px;
      margin: 0 auto;
      padding: 20px 24px;
    }

    .page-section {
      padding: 32px 0;
      border-bottom: 1px solid rgba(201, 150, 58, 0.15);
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .page-section.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .page-section:last-child { border-bottom: none; }

    .contact-cards {
      display: flex;
      gap: 24px;
      justify-content: center;
      flex-wrap: wrap;
      padding: 16px 0;
    }

    .contact-card {
      text-align: center;
      flex: 1;
      min-width: 200px;
      max-width: 250px;
      padding: 24px 16px;
    }

    .contact-card .icon {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      background: var(--gold);
      color: var(--cream);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      margin-bottom: 16px;
    }

    .contact-card p {
      font-size: 1.05rem;
      line-height: 1.7;
      color: var(--text);
      margin: 4px 0;
    }

    .contact-card a {
      color: var(--gold);
      text-decoration: none;
      border-bottom: 1px solid rgba(201, 150, 58, 0.3);
      transition: border-color 0.3s ease;
    }

    .contact-card a:hover {
      border-bottom-color: var(--gold);
    }

    .map-container {
      border-radius: 4px;
      overflow: hidden;
    }

    .map-container iframe {
      display: block;
      width: 100%;
      height: 400px;
      border: none;
    }
  </style>
</head>

<body>
  <% include partials/menu %>
    <div class="container bg-light">
      <div class="styled-page">
        <div class="page-header">
          <p class="subtitle">Get in Touch</p>
          <h1>Contact Us</h1>
        </div>

        <div class="page-content">

          <div class="page-section">
            <div class="contact-cards">
              <div class="contact-card">
                <div class="icon"><i class="fas fa-phone"></i></div>
                <p><a href="tel:+61288148597">+61 (02) 8814 8597</a></p>
              </div>
              <div class="contact-card">
                <div class="icon"><i class="fas fa-map-marker-alt"></i></div>
                <a href="https://www.google.com/maps/dir/?api=1&destination=Shree+Swaminarayan+Temple,+1-3+Tasha+Place,+Kings+Park+NSW+2148" target="_blank">
                  <p>1-3 Tasha Place</p>
                  <p>Kings Park</p>
                  <p>NSW 2148</p>
                </a>
              </div>
              <div class="contact-card">
                <div class="icon"><i class="fas fa-envelope"></i></div>
                <p><a href="mailto:info@sydneytemple.org">info@sydneytemple.org</a></p>
              </div>
            </div>
          </div>

          <div class="page-section">
            <div class="map-container">
              <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3317.591899697112!2d150.90614031474516!3d-33.74536752009348!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b1298d8b12c7341%3A0x42817fab4480e2b3!2sShree%20Swaminarayan%20Temple!5e0!3m2!1sen!2sau!4v1569031340874!5m2!1sen!2sau" allowfullscreen=""></iframe>
            </div>
          </div>

        </div>
      </div>
    </div>

  <script>
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.page-section').forEach(function (el) { observer.observe(el); });
  </script>

  <% include partials/footer %>
</body>

</html>
