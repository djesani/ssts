{
  "name": "admin",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "   npx ng serve admin    --proxy-config proxy.conf.json",
    "start:v1": "npx ng serve admin    --proxy-config proxy.conf.json",
    "start:v2": "npx ng serve admin-v2 --proxy-config proxy.conf.json",
    "build": "   npx ng build admin    -c production --base-href=/admin/    --output-path=../../admin",
    "build:v1": "npx ng build admin    -c production --base-href=/admin/    --output-path=../../admin",
    "build:v2": "npx ng build admin-v2 -c production --base-href=/admin-v2/ --output-path=../../admin-v2",
    "watch": "   npx ng build admin    -c production --base-href=/admin/    --output-path=../../admin --watch",
    "server-mock": "npx json-server --watch ./server-mock/database.json",
    "update": "  npx npm-check-updates -u"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.3",
    "@angular/common": "^21.1.3",
    "@angular/compiler": "^21.1.3",
    "@angular/core": "^21.1.3",
    "@angular/forms": "^21.1.3",
    "@angular/localize": "^21.1.3",
    "@angular/platform-browser": "^21.1.3",
    "@angular/platform-browser-dynamic": "~21.1.3",
    "@angular/router": "^21.1.3",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@kolkov/angular-editor": "^3.0.5",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "ngx-spinner": "^21.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.3",
    "@types/node": "^25.2.1",
    "jsdom": "^28.0.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  }
}